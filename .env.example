# Copy to .env.local for local dev. For production, set the same two variables
# in Vercel: Project → Settings → Environment Variables, then redeploy.
# Values come from Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-side only (no VITE_ prefix — never exposed to the browser).
# Powers /api/score-script. Set in Vercel env vars; from console.anthropic.com.
# Local dev note: `npm run dev` doesn't run API functions — use `npx vercel dev` to test locally.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
